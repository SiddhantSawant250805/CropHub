# Server Configuration
PORT=5000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Secret
JWT_SECRET=your_super_secure_jwt_secret_key_here_minimum_32_characters

# Encryption Key for Financial Data (AES-256-CBC requires 32 bytes)
ENCRYPTION_KEY=your_32_character_encryption_key_here_exactly_32_chars
ENCRYPTION_IV=your_16_char_iv_16

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=crophub-soil-images

# External API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MARKET_API_KEY=your_market_pricing_api_key

# Python ML Service URL
ML_SERVICE_URL=http://localhost:8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
